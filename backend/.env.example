# ─── Gopiram Saree backend configuration ──────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# Port the server listens on. Cloud hosts usually set this automatically.
PORT=3000

# ─── WhatsApp (official Meta WhatsApp Business API) ────────────────────────────
WHATSAPP_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
SHOP_WHATSAPP=919876543210

# ─── Server / TLS ─────────────────────────────────────────────────────────────
# Set to "true" on a cloud host where TLS (https) is handled by the platform's
# load balancer. Leave unset for local LAN dev (uses the self-signed certs).
# SERVE_HTTP=true

# Optional: override the local TLS cert/key paths.
# TLS_CERT_PATH=/abs/path/to/cert.pem
# TLS_KEY_PATH=/abs/path/to/key.pem

# Comma-separated allowed front-end origins (production). Unset = allow all (dev).
# CORS_ORIGINS=https://app.gopiramsarees.in

# ─── Persistent storage (production) ──────────────────────────────────────────
# On Railway, attach a volume mounted at /data and point these at it so the
# database and uploaded photos survive restarts and redeploys.
# DB_PATH=/data/gopiram.db
# UPLOADS_DIR=/data/uploads

# Secret for signing session tokens. MUST be a long random string in production.
# Generate with: openssl rand -hex 32
# JWT_SECRET=change-me-to-a-long-random-string

# ─── Tally integration ────────────────────────────────────────────────────────
# Point at Tally on the SHOP PC. When the backend runs in the cloud it cannot
# reach the shop's localhost — the Phase 2 sync agent handles that instead.
# TALLY_XML_URL=http://localhost:9000
# TALLY_CONNECT_URL=http://localhost:9090

# Shared secret the Tally sync agent uses to push stock to the cloud (Phase 2).
# SYNC_AGENT_TOKEN=change-me-to-a-long-random-string

# ─── Database off-site backup (Litestream → Cloudflare R2) ────────────────────
# Continuously replicates the SQLite database to a Cloudflare R2 bucket so it can
# be restored if the server/volume is ever lost. Get these from R2 dashboard.
# LITESTREAM_REPLICA_URL=s3://your-bucket-name/gopiram.db
# LITESTREAM_ACCESS_KEY_ID=your_r2_access_key_id
# LITESTREAM_SECRET_ACCESS_KEY=your_r2_secret_access_key
# LITESTREAM_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
