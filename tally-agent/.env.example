# Copy this file to ".env" and fill in the values.

# Your cloud backend address (no trailing slash)
CLOUD_URL=https://api.gopiramsarees.in

# The shared secret. MUST exactly match the SYNC_AGENT_TOKEN set on the server (Railway).
SYNC_TOKEN=paste-the-same-token-as-on-the-server

# Tally's local address (default is correct for Tally on the same PC)
TALLY_URL=http://localhost:9000

# How often to sync, in minutes
INTERVAL_MINUTES=5
